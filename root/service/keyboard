let fd;
let keys = "";

function keyupdate() {
    write(fd, keys);
}
this.main = function() {
    fd = fopen("/dev/keyboard", "w", 777);
    thread(keyupdate, []);
    sleep(-1);
}

document.addEventListener("keydown", (e) => {
    keys+=e.key;
});

document.addEventListener("keyup", (e) => {
    keys = keys.replaceAll(e.key, "");
});