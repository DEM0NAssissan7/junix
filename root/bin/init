let k = 0;
this.main = () => {
    k++;
    this.open("/bin/hello");
    
    // Test
    let fd = fopen("/hello", "w");
    write(fd, "Hello World!");
    fclose(fd);
    fd = fopen("/hello", "r");
    console.log(read(fd));
    fclose(fd);

    fd = opendir("/root");
    console.log(listdir(fd));

    exit();
}
this.open = function(path) {
    exec(path);
    fork();
    exec("/bin/init");
}