// JUNIX Init system: inspired by FreeBSD rc
this.main = () => {
    let fd = fopen("/etc/rc", "r");
    let paths = read(fd).split("\n");
    for(let path of paths)
        this.open(path);
    sleep(-1);
}
this.open = function(path) {
    console.log("Initializing " + path)
    exec(path);
    fork();
}